---
import { execFileSync } from 'node:child_process';

type Commit = {
  hash: string;
  date: string;
  subject: string;
};

type DayGroup = {
  date: string;
  commits: Commit[];
};

type MonthGroup = {
  month: string;
  days: DayGroup[];
  count: number;
  hasToday: boolean;
};

type YearGroup = {
  year: string;
  months: MonthGroup[];
  count: number;
  hasToday: boolean;
};

const readCommits = (): Commit[] => {
  try {
    const output = execFileSync(
      'git',
      ['log', '--date=short', '--pretty=format:%h%x09%ad%x09%s'],
      {
        cwd: process.cwd(),
        encoding: 'utf8',
      }
    );

    return output
      .split('\n')
      .filter(Boolean)
      .map((line) => {
        const [hash, date, ...subjectParts] = line.split('\t');
        return {
          hash,
          date,
          subject: subjectParts.join('\t'),
        };
      })
      .filter((commit) => commit.hash && commit.date && commit.subject);
  } catch {
    const fallbackHash = process.env.VERCEL_GIT_COMMIT_SHA?.slice(0, 7);
    const fallbackSubject = process.env.VERCEL_GIT_COMMIT_MESSAGE;

    if (!fallbackHash || !fallbackSubject) return [];

    return [
      {
        hash: fallbackHash,
        date: new Date().toISOString().slice(0, 10),
        subject: fallbackSubject,
      },
    ];
  }
};

const today = new Date().toISOString().slice(0, 10);

const groupedByDay = readCommits().reduce<Map<string, Commit[]>>((groups, commit) => {
  groups.set(commit.date, [...(groups.get(commit.date) ?? []), commit]);
  return groups;
}, new Map());

const years = Array.from(groupedByDay, ([date, commits]) => ({
  date,
  commits,
})).reduce<YearGroup[]>((groups, day) => {
  const [year, month] = day.date.split('-');
  const yearGroup =
    groups.find((group) => group.year === year) ??
    groups[
      groups.push({
        year,
        months: [],
        count: 0,
        hasToday: false,
      }) - 1
    ];
  const monthGroup =
    yearGroup.months.find((group) => group.month === month) ??
    yearGroup.months[
      yearGroup.months.push({
        month,
        days: [],
        count: 0,
        hasToday: false,
      }) - 1
    ];

  const isToday = day.date === today;
  monthGroup.days.push(day);
  monthGroup.count += day.commits.length;
  monthGroup.hasToday ||= isToday;
  yearGroup.count += day.commits.length;
  yearGroup.hasToday ||= isToday;

  return groups;
}, []);
---

{
  years.length > 0 ? (
    <div class="update-history">
      {years.map((year) => (
        <details class="update-history-year" open={year.hasToday}>
          <summary id={`update-${year.year}`}>
            <span>{year.year}</span>
            <small>{year.count} updates</small>
          </summary>
          <div class="update-history-months">
            {year.months.map((month) => (
              <details class="update-history-month" open={month.hasToday}>
                <summary id={`update-${year.year}-${month.month}`}>
                  <span>{month.month}月</span>
                  <small>{month.count} updates</small>
                </summary>
                <div class="update-history-days">
                  {month.days.map(({ date, commits }) => (
                    <details class="update-history-day" open={date === today}>
                      <summary id={`update-${date}`}>
                        <span>{date}</span>
                        <small>{commits.length} updates</small>
                      </summary>
                      <ol>
                        {commits.map((commit) => (
                          <li>
                            <span>{commit.subject}</span>
                            <code>{commit.hash}</code>
                          </li>
                        ))}
                      </ol>
                    </details>
                  ))}
                </div>
              </details>
            ))}
          </div>
        </details>
      ))}
    </div>
  ) : (
    <p class="update-history-empty">暂时没有读取到 Git 更新记录。</p>
  )
}
