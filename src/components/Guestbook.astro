<section class="guestbook" aria-labelledby="guestbook-title">
  <div class="guestbook-header">
    <h2 id="guestbook-title">留言区</h2>
    <div class="guestbook-header-actions">
      <span class="guestbook-user" id="guestbook-user"></span>
      <a class="guestbook-login" id="guestbook-login" href="/api/github-auth?action=login">GitHub Login</a>
      <a class="guestbook-logout" id="guestbook-logout" href="/api/github-auth?action=logout" hidden>Logout</a>
      <button class="guestbook-moderate-button" id="guestbook-moderate" type="button">Moderate</button>
    </div>
  </div>

  <form class="guestbook-form" id="guestbook-form">
    <label>
      <span>留言</span>
      <textarea id="guestbook-message" name="message" rows="4" maxlength="320" placeholder="在这里写下留言" required></textarea>
    </label>

    <div class="guestbook-actions">
      <span id="guestbook-count">0 / 320</span>
      <button type="submit">留下留言</button>
    </div>
  </form>

  <div class="guestbook-board" aria-live="polite">
    <p class="guestbook-empty" id="guestbook-empty">还没有留言。</p>
    <ol class="guestbook-list" id="guestbook-list"></ol>
    <p class="guestbook-status" id="guestbook-status"></p>
  </div>
</section>

<script>
  const storageKey = 'gravis-home-guestbook';
  const adminTokenKey = 'gravis-home-guestbook-admin-token';
  const endpoint = '/api/guestbook';
  let activeMessages = [];
  let backendEnabled = false;
  let moderationEnabled = false;
  let currentUser = null;

  const createLocalId = () => {
    return `local-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;
  };

  const readMessages = () => {
    try {
      let changed = false;
      const messages = JSON.parse(localStorage.getItem(storageKey) || '[]').map((item) => {
        const nextItem = {
          ...item,
          id: item.id || createLocalId(),
          parentId: item.parentId || '',
        };
        if (!item.id || item.parentId === undefined) changed = true;
        return nextItem;
      });
      if (changed) writeMessages(messages);
      return messages;
    } catch {
      return [];
    }
  };

  const writeMessages = (messages) => {
    localStorage.setItem(storageKey, JSON.stringify(messages.slice(0, 20)));
  };

  const markSynced = (messagesToMark) => {
    const syncedKeys = new Set(
      messagesToMark.map(
        (item) => `${item.createdAt}:${item.name || ''}:${item.message}:${item.parentId || ''}`
      )
    );
    const messages = readMessages().map((item) => {
      const key = `${item.createdAt}:${item.name || ''}:${item.message}:${item.parentId || ''}`;
      return syncedKeys.has(key) ? { ...item, syncedAt: new Date().toISOString() } : item;
    });
    writeMessages(messages);
  };

  const markClaimed = (messagesToMark) => {
    const claimedKeys = new Set(
      messagesToMark.map(
        (item) => `${item.createdAt}:${item.name || ''}:${item.message}:${item.parentId || ''}`
      )
    );
    const messages = readMessages().map((item) => {
      const key = `${item.createdAt}:${item.name || ''}:${item.message}:${item.parentId || ''}`;
      return claimedKeys.has(key) ? { ...item, claimedAt: new Date().toISOString() } : item;
    });
    writeMessages(messages);
  };

  const formatDate = (value) => {
    return new Intl.DateTimeFormat('zh-CN', {
      month: 'short',
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit',
    }).format(new Date(value));
  };

  const setStatus = (message) => {
    const status = document.querySelector('#guestbook-status');
    if (!status) return;
    status.textContent = message;
  };

  const updateAuthUi = () => {
    const user = document.querySelector('#guestbook-user');
    const login = document.querySelector('#guestbook-login');
    const logout = document.querySelector('#guestbook-logout');
    const submit = document.querySelector('#guestbook-form button[type="submit"]');
    if (!user || !login || !logout || !submit) return;

    if (currentUser) {
      user.textContent = `@${currentUser.login}`;
      login.hidden = true;
      logout.hidden = false;
      submit.disabled = false;
      submit.textContent = '留下留言';
      return;
    }

    user.textContent = '';
    login.hidden = false;
    logout.hidden = true;
    submit.disabled = true;
    submit.textContent = '请先登录';
  };

  const fetchSession = async () => {
    try {
      const response = await fetch('/api/github-auth?action=session');
      if (!response.ok) throw new Error('Session unavailable.');
      const data = await response.json();
      currentUser = data.user || null;
    } catch {
      currentUser = null;
    }
    updateAuthUi();
  };

  const getAdminToken = () => {
    return sessionStorage.getItem(adminTokenKey) || '';
  };

  const setAdminToken = (token) => {
    if (token) {
      sessionStorage.setItem(adminTokenKey, token);
    } else {
      sessionStorage.removeItem(adminTokenKey);
    }
    moderationEnabled = Boolean(token);
  };

  const getDisplayName = (item) => {
    if (!item) return '匿名';
    return item.githubLogin ? `@${item.githubLogin}` : item.name || '匿名';
  };

  const buildThreads = (messages) => {
    const byId = new Map(messages.map((item) => [item.id, item]));
    const chronological = [...messages].sort((left, right) => {
      return new Date(left.createdAt) - new Date(right.createdAt);
    });
    const floorById = new Map(chronological.map((item, index) => [item.id, index + 1]));
    const topLevel = [];
    const repliesByRoot = new Map();

    const findRootId = (item) => {
      let current = item;
      const seen = new Set();
      while (current?.parentId && byId.has(current.parentId) && !seen.has(current.id)) {
        seen.add(current.id);
        current = byId.get(current.parentId);
      }
      return current?.id || item.parentId || item.id;
    };

    for (const item of messages) {
      if (!item.parentId) {
        topLevel.push(item);
        continue;
      }

      const rootId = findRootId(item);
      const replies = repliesByRoot.get(rootId) || [];
      replies.push(item);
      repliesByRoot.set(rootId, replies);
    }

    topLevel.sort((left, right) => new Date(right.createdAt) - new Date(left.createdAt));
    for (const replies of repliesByRoot.values()) {
      replies.sort((left, right) => new Date(left.createdAt) - new Date(right.createdAt));
    }

    return { byId, floorById, topLevel, repliesByRoot };
  };

  const messageKey = (item) => {
    return item.id || `${item.createdAt}:${item.name || ''}:${item.message}:${item.parentId || ''}`;
  };

  const mergeMessages = (...messageGroups) => {
    const merged = new Map();
    for (const messages of messageGroups) {
      for (const item of messages) {
        merged.set(messageKey(item), item);
      }
    }
    return [...merged.values()].sort((left, right) => new Date(right.createdAt) - new Date(left.createdAt));
  };

  const createReplyForm = (parent) => {
    const form = document.createElement('form');
    form.className = 'guestbook-reply-form';
    form.dataset.parentId = parent.id;

    const label = document.createElement('label');
    const labelText = document.createElement('span');
    labelText.textContent = `回复 ${getDisplayName(parent)}`;

    const textarea = document.createElement('textarea');
    textarea.name = 'message';
    textarea.rows = 3;
    textarea.maxLength = 320;
    textarea.placeholder = '写下回复';
    textarea.required = true;

    const actions = document.createElement('div');
    actions.className = 'guestbook-reply-actions';

    const cancel = document.createElement('button');
    cancel.type = 'button';
    cancel.className = 'guestbook-reply-cancel';
    cancel.textContent = 'Cancel';

    const submit = document.createElement('button');
    submit.type = 'submit';
    submit.textContent = 'Reply';

    actions.append(cancel, submit);
    label.append(labelText, textarea);
    form.append(label, actions);
    return form;
  };

  const createEntry = (item, context = {}) => {
    const { byId = new Map(), floorById = new Map(), rootId = '', isReply = false } = context;
    const entry = document.createElement('li');
    entry.className = isReply ? 'guestbook-entry guestbook-reply' : 'guestbook-entry';
    entry.dataset.messageId = item.id;

    const meta = document.createElement('div');
    meta.className = 'guestbook-entry-meta';

    if (item.avatarUrl) {
      const avatar = document.createElement('img');
      avatar.className = 'guestbook-avatar';
      avatar.src = item.avatarUrl;
      avatar.alt = '';
      avatar.loading = 'lazy';
      meta.append(avatar);
    }

    const name = document.createElement('strong');
    name.textContent = getDisplayName(item);

    const time = document.createElement('time');
    time.dateTime = item.createdAt;
    time.textContent = formatDate(item.createdAt);

    if (isReply) {
      const floor = document.createElement('span');
      floor.className = 'guestbook-floor';
      floor.textContent = `${floorById.get(item.id) || ''}楼`;
      meta.append(floor);

      const parent = byId.get(item.parentId);
      if (parent && parent.id !== rootId) {
        const replyingTo = document.createElement('span');
        replyingTo.className = 'guestbook-reply-target';
        replyingTo.textContent = `回复 ${getDisplayName(parent)}`;
        meta.append(replyingTo);
      }
    }

    const message = document.createElement('p');
    message.textContent = item.message;

    const replyButton = document.createElement('button');
    replyButton.type = 'button';
    replyButton.className = 'guestbook-reply-button';
    replyButton.dataset.replyTo = item.id;
    replyButton.textContent = 'Reply';

    const likeButton = document.createElement('button');
    const likedBy = Array.isArray(item.likedBy) ? item.likedBy : [];
    const isLiked = Boolean(currentUser && likedBy.includes(currentUser.login));
    likeButton.type = 'button';
    likeButton.className = isLiked ? 'guestbook-like-button is-liked' : 'guestbook-like-button';
    likeButton.dataset.likeId = item.id;
    likeButton.textContent = `赞 ${item.likeCount || likedBy.length || 0}`;
    likeButton.disabled = !currentUser || !item.id?.startsWith('github-');

    meta.append(name, time);
    if (currentUser) meta.append(replyButton);
    meta.append(likeButton);

    if (moderationEnabled && item.id?.startsWith('github-')) {
      const hideButton = document.createElement('button');
      hideButton.type = 'button';
      hideButton.className = 'guestbook-hide-button';
      hideButton.dataset.hideId = item.id;
      hideButton.textContent = 'Hide';
      meta.append(hideButton);
    }

    entry.append(meta, message);

    return entry;
  };

  const renderMessages = (messages = activeMessages) => {
    const list = document.querySelector('#guestbook-list');
    const empty = document.querySelector('#guestbook-empty');
    if (!list || !empty) return;

    activeMessages = messages;
    list.textContent = '';
    empty.hidden = messages.length > 0;
    const threadContext = buildThreads(messages);
    const { topLevel, repliesByRoot } = threadContext;

    for (const item of topLevel) {
      const entry = createEntry(item, threadContext);
      const replies = repliesByRoot.get(item.id) || [];
      if (replies.length > 0) {
        const replyList = document.createElement('ol');
        replyList.className = 'guestbook-replies';
        for (const reply of replies) {
          replyList.append(createEntry(reply, { ...threadContext, rootId: item.id, isReply: true }));
        }
        entry.append(replyList);
      }
      list.append(entry);
    }
  };

  const fetchRemoteMessages = async () => {
    const response = await fetch(endpoint);
    if (!response.ok) throw new Error('Guestbook backend unavailable.');
    const data = await response.json();
    backendEnabled = true;
    return data.messages || [];
  };

  const postRemoteMessage = async (item) => {
    const response = await fetch(endpoint, {
      method: 'POST',
      headers: {
        'content-type': 'application/json',
      },
      body: JSON.stringify(item),
    });

    if (response.status === 401) throw new Error('GitHub login required.');
    if (!response.ok) throw new Error('Guestbook backend unavailable.');
    backendEnabled = true;
    return response.json();
  };

  const hideRemoteMessage = async (id) => {
    const response = await fetch(endpoint, {
      method: 'PATCH',
      headers: {
        authorization: `Bearer ${getAdminToken()}`,
        'content-type': 'application/json',
      },
      body: JSON.stringify({ id, hidden: true }),
    });

    if (!response.ok) throw new Error('Hide request failed.');
    return response.json();
  };

  const likeRemoteMessage = async (id) => {
    const response = await fetch(endpoint, {
      method: 'PATCH',
      headers: {
        'content-type': 'application/json',
      },
      body: JSON.stringify({ action: 'like', id }),
    });

    if (response.status === 401) throw new Error('GitHub login required.');
    if (!response.ok) throw new Error('Like request failed.');
    return response.json();
  };

  const claimRemoteMessage = async (remoteItem, localItem) => {
    const response = await fetch(endpoint, {
      method: 'PATCH',
      headers: {
        'content-type': 'application/json',
      },
      body: JSON.stringify({
        action: 'claim',
        id: remoteItem.id,
        message: localItem.message,
        createdAt: localItem.createdAt,
        parentId: localItem.parentId || '',
      }),
    });

    if (!response.ok) throw new Error('Claim request failed.');
    return response.json();
  };

  const migrateLocalAuthors = async (remoteMessages) => {
    if (!currentUser) return remoteMessages;

    const localMessages = readMessages().filter((item) => !item.claimedAt);
    if (localMessages.length === 0) return remoteMessages;

    const claimed = [];
    for (const remoteItem of remoteMessages) {
      if (remoteItem.githubLogin) continue;

      const localItem = localMessages.find((item) => {
        return (
          item.message === remoteItem.message &&
          item.createdAt === remoteItem.createdAt &&
          (item.parentId || '') === (remoteItem.parentId || '')
        );
      });

      if (!localItem) continue;

      try {
        await claimRemoteMessage(remoteItem, localItem);
        claimed.push(localItem);
      } catch {
        // Keep going: one old message may fail if it was made on another device.
      }
    }

    if (claimed.length === 0) return remoteMessages;

    markClaimed(claimed);
    setStatus(`已为 ${claimed.length} 条旧留言补上 GitHub 身份。`);
    return fetchRemoteMessages();
  };

  const saveMessage = async (item, successStatus) => {
    try {
      const result = await postRemoteMessage(item);
      renderMessages(await fetchRemoteMessages());
      setStatus(successStatus);
      return result.message;
    } catch {
      if (!currentUser) {
        setStatus('Please sign in with GitHub first.');
        return item;
      }
      writeMessages([item, ...readMessages()]);
      renderMessages(mergeMessages(readMessages(), activeMessages));
      setStatus('公共留言区暂不可用，已先保存在本地。');
      return item;
    }
  };

  const syncLocalMessages = async () => {
    const unsynced = readMessages()
      .filter((item) => !item.syncedAt)
      .sort((left, right) => new Date(left.createdAt) - new Date(right.createdAt));
    if (!backendEnabled || unsynced.length === 0) return;

    const synced = [];
    const idMap = new Map();
    for (const item of unsynced) {
      try {
        const parentId = idMap.get(item.parentId) || item.parentId || '';
        const result = await postRemoteMessage({ ...item, parentId });
        if (item.id && result.message?.id) idMap.set(item.id, result.message.id);
        synced.push(item);
      } catch {
        break;
      }
    }

    if (synced.length > 0) {
      markSynced(synced);
      renderMessages(await fetchRemoteMessages());
      setStatus(`已同步 ${synced.length} 条本地留言。`);
    }
  };

  const setupGuestbook = () => {
    const form = document.querySelector('#guestbook-form');
    const messageInput = document.querySelector('#guestbook-message');
    const count = document.querySelector('#guestbook-count');
    const moderateButton = document.querySelector('#guestbook-moderate');
    if (!form || !messageInput || !count || !moderateButton) return;

    const updateCount = () => {
      count.textContent = `${messageInput.value.length} / ${messageInput.maxLength}`;
    };

    messageInput.addEventListener('input', updateCount);
    setAdminToken(getAdminToken());

    moderateButton.addEventListener('click', () => {
      if (moderationEnabled) {
        setAdminToken('');
        renderMessages(activeMessages);
        setStatus('Moderation disabled.');
        return;
      }

      const token = window.prompt('Admin token');
      if (!token) return;
      setAdminToken(token.trim());
      renderMessages(activeMessages);
      setStatus('Moderation enabled.');
    });

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!currentUser) {
        setStatus('Please sign in with GitHub first.');
        return;
      }
      const message = messageInput.value.trim();
      if (!message) return;

      const item = {
        id: createLocalId(),
        name: currentUser.name || currentUser.login,
        githubLogin: currentUser.login,
        avatarUrl: currentUser.avatarUrl,
        profileUrl: currentUser.profileUrl,
        message,
        createdAt: new Date().toISOString(),
        parentId: '',
      };

      await saveMessage(item, '留言已公开保存。');
      form.reset();
      updateCount();
    });

    document.addEventListener('click', (event) => {
      const hideButton = event.target.closest?.('.guestbook-hide-button');
      if (!hideButton) return;

      const id = hideButton.dataset.hideId;
      if (!id || !window.confirm('Hide this comment?')) return;

      hideButton.disabled = true;
      hideRemoteMessage(id)
        .then(async () => {
          renderMessages(await fetchRemoteMessages());
          setStatus('Comment hidden.');
        })
        .catch(() => {
          hideButton.disabled = false;
          setStatus('Hide failed. Check the admin token.');
        });
    });

    document.addEventListener('click', (event) => {
      const likeButton = event.target.closest?.('.guestbook-like-button');
      if (!likeButton) return;

      const id = likeButton.dataset.likeId;
      if (!id) return;
      if (!currentUser) {
        setStatus('Please sign in with GitHub first.');
        return;
      }

      likeButton.disabled = true;
      likeRemoteMessage(id)
        .then(async () => {
          renderMessages(await fetchRemoteMessages());
          setStatus('点赞已更新。');
        })
        .catch(() => {
          likeButton.disabled = false;
          setStatus('点赞失败，请稍后再试。');
        });
    });

    document.addEventListener('click', (event) => {
      const replyButton = event.target.closest?.('.guestbook-reply-button');
      if (!replyButton) return;

      const parent = activeMessages.find((item) => item.id === replyButton.dataset.replyTo);
      const entry = replyButton.closest('.guestbook-entry');
      if (!parent || !entry) return;

      document.querySelectorAll('.guestbook-reply-form').forEach((replyForm) => replyForm.remove());
      entry.append(createReplyForm(parent));
    });

    document.addEventListener('click', (event) => {
      if (!event.target.closest?.('.guestbook-reply-cancel')) return;
      event.target.closest('.guestbook-reply-form')?.remove();
    });

    document.addEventListener('submit', async (event) => {
      const replyForm = event.target.closest?.('.guestbook-reply-form');
      if (!replyForm) return;

      event.preventDefault();
      const formData = new FormData(replyForm);
      if (!currentUser) {
        setStatus('Please sign in with GitHub first.');
        replyForm.remove();
        return;
      }
      const message = String(formData.get('message') || '').trim();
      if (!message) return;

      const item = {
        id: createLocalId(),
        name: currentUser.name || currentUser.login,
        githubLogin: currentUser.login,
        avatarUrl: currentUser.avatarUrl,
        profileUrl: currentUser.profileUrl,
        message,
        createdAt: new Date().toISOString(),
        parentId: replyForm.dataset.parentId || '',
      };

      await saveMessage(item, '回复已公开保存。');
      replyForm.remove();
    });

    updateCount();
    updateAuthUi();
    fetchSession().then(() => renderMessages(activeMessages));
    renderMessages(readMessages());
    fetchRemoteMessages()
      .then(async (messages) => {
        await fetchSession();
        const nextMessages = await migrateLocalAuthors(messages);
        renderMessages(nextMessages);
        setStatus('Public guestbook connected.');
        return syncLocalMessages();
      })
      .catch(() => {
        setStatus('公共留言区尚未配置，当前留言只保存在本地。');
      });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupGuestbook, { once: true });
  } else {
    setupGuestbook();
  }
</script>
