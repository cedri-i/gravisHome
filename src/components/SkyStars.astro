<div id="sky-stars" aria-hidden="true"></div>

<script is:inline>
  console.log('SkyStars loaded');

  const root = document.getElementById('sky-stars');

  function createStar() {
    if (!root) return;

    const star = document.createElement('span');
    star.className = 'sky-star';

    star.style.left = `${Math.random() * 100}vw`;
    star.style.top = `${Math.random() * 100}vh`;
    star.style.width = `${2 + Math.random() * 4}px`;
    star.style.height = star.style.width;

    root.appendChild(star);

    setTimeout(() => star.remove(), 12000);
  }

  for (let i = 0; i < 160; i++) createStar();

  setInterval(createStar, 300);
</script>