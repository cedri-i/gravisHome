<canvas id="sky-leaves" aria-hidden="true"></canvas>

<style>
  #sky-leaves {
    display: none;
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 2;
  }

  :root[data-theme="light"] #sky-leaves {
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    #sky-leaves {
      display: none;
    }
  }
</style>

<script is:inline>
(() => {
  const canvas = document.getElementById("sky-leaves");
  if (!canvas || window.__SKY_LEAVES__) return;
  window.__SKY_LEAVES__ = true;

  const ctx = canvas.getContext("2d", { alpha: true });
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  if (reduceMotion.matches) return;

  let w = 0;
  let h = 0;
  let dpr = 1;
  let lastTime = performance.now();
  let windTime = 0;

  const leaves = [];
  const LEAF_COUNT = 24;

  function rand(min, max) {
    return min + Math.random() * (max - min);
  }

  function resize() {
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    w = window.innerWidth;
    h = window.innerHeight;

    canvas.width = Math.floor(w * dpr);
    canvas.height = Math.floor(h * dpr);
    canvas.style.width = w + "px";
    canvas.style.height = h + "px";

    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function makeLeaf(initial = false) {
    const depth = rand(0.45, 1.35);

    const palettes = [
      ["#b65b1d", "#e09a36", "#6f3416"],
      ["#9f3d22", "#d46b35", "#5a2418"],
      ["#c18a25", "#f1c35a", "#7a5019"],
      ["#7f5a25", "#b98234", "#422d16"],
      ["#a24a2a", "#d98245", "#51251c"]
    ];

    const color = palettes[Math.floor(Math.random() * palettes.length)];

    return {
      x: rand(-w * 0.15, w * 1.15),
      y: initial ? rand(-h, h) : rand(-h * 0.25, -40),
      size: rand(12, 28) * depth,
      depth,
      vx: rand(-0.12, 0.28) * depth,
      vy: rand(0.45, 1.35) * depth,
      swing: rand(18, 58) * depth,
      swingSpeed: rand(0.7, 1.8),
      phase: rand(0, Math.PI * 2),
      rot: rand(0, Math.PI * 2),
      rotSpeed: rand(-1.4, 1.4),
      flip: rand(0.55, 1),
      alpha: rand(0.45, 0.9),
      color
    };
  }

  function resetLeaf(leaf) {
    const fresh = makeLeaf(false);
    Object.assign(leaf, fresh);
    leaf.x = rand(-w * 0.2, w * 1.1);
  }

  function drawLeaf(leaf, t) {
    const s = leaf.size;
    const [dark, mid, vein] = leaf.color;

    ctx.save();
    ctx.translate(leaf.x, leaf.y);
    ctx.rotate(leaf.rot);
    ctx.scale(1, leaf.flip * Math.sin(t * leaf.swingSpeed + leaf.phase) * 0.35 + 0.75);

    ctx.globalAlpha = leaf.alpha;
    ctx.globalCompositeOperation = "source-over";

    const grad = ctx.createLinearGradient(-s * 0.45, -s, s * 0.6, s);
    grad.addColorStop(0, mid);
    grad.addColorStop(0.52, dark);
    grad.addColorStop(1, "#2f1b10");

    ctx.fillStyle = grad;
    ctx.beginPath();

    /*
      这不是标准椭圆，而是用贝塞尔画出一片有尖端、
      有左右不对称、有自然弯曲的叶子。
    */
    ctx.moveTo(0, -s);
    ctx.bezierCurveTo(s * 0.7, -s * 0.68, s * 0.72, s * 0.1, s * 0.16, s * 0.88);
    ctx.bezierCurveTo(s * 0.02, s * 1.05, -s * 0.1, s * 1.05, -s * 0.2, s * 0.86);
    ctx.bezierCurveTo(-s * 0.78, s * 0.02, -s * 0.58, -s * 0.66, 0, -s);
    ctx.closePath();
    ctx.fill();

    ctx.strokeStyle = "rgba(255, 223, 150, 0.22)";
    ctx.lineWidth = Math.max(0.6, s * 0.035);
    ctx.stroke();

    ctx.strokeStyle = vein;
    ctx.globalAlpha = leaf.alpha * 0.55;
    ctx.lineWidth = Math.max(0.7, s * 0.045);

    ctx.beginPath();
    ctx.moveTo(0, -s * 0.82);
    ctx.quadraticCurveTo(s * 0.06, -s * 0.1, -s * 0.05, s * 0.82);
    ctx.stroke();

    ctx.lineWidth = Math.max(0.4, s * 0.02);

    for (let i = 0; i < 4; i++) {
      const yy = -s * 0.45 + i * s * 0.28;

      ctx.beginPath();
      ctx.moveTo(0, yy);
      ctx.quadraticCurveTo(s * 0.22, yy + s * 0.08, s * 0.42, yy + s * 0.18);
      ctx.stroke();

      ctx.beginPath();
      ctx.moveTo(0, yy + s * 0.04);
      ctx.quadraticCurveTo(-s * 0.22, yy + s * 0.13, -s * 0.38, yy + s * 0.25);
      ctx.stroke();
    }

    ctx.globalAlpha = leaf.alpha * 0.45;
    ctx.strokeStyle = "rgba(80, 42, 20, 0.8)";
    ctx.lineWidth = Math.max(0.7, s * 0.035);

    ctx.beginPath();
    ctx.moveTo(-s * 0.05, s * 0.82);
    ctx.quadraticCurveTo(-s * 0.12, s * 1.04, -s * 0.22, s * 1.25);
    ctx.stroke();

    ctx.restore();
  }

  function frame(now) {
    const dt = Math.min((now - lastTime) / 1000, 0.033);
    lastTime = now;
    windTime += dt;

    ctx.clearRect(0, 0, w, h);

    const baseWind =
      Math.sin(windTime * 0.42) * 0.28 +
      Math.sin(windTime * 1.17) * 0.12;

    for (const leaf of leaves) {
      const swing = Math.sin(windTime * leaf.swingSpeed + leaf.phase) * leaf.swing;
      const gust = baseWind * leaf.depth;

      leaf.x += (leaf.vx + gust) * dt * 60;
      leaf.y += leaf.vy * dt * 60;
      leaf.rot += leaf.rotSpeed * dt;

      const visualX = leaf.x + swing;
      const oldX = leaf.x;
      leaf.x = visualX;
      drawLeaf(leaf, windTime);
      leaf.x = oldX;

      if (
        leaf.y > h + leaf.size * 3 ||
        leaf.x < -w * 0.35 ||
        leaf.x > w * 1.35
      ) {
        resetLeaf(leaf);
      }
    }

    requestAnimationFrame(frame);
  }

  resize();
  window.addEventListener("resize", resize, { passive: true });

  for (let i = 0; i < LEAF_COUNT; i++) {
    leaves.push(makeLeaf(true));
  }

  requestAnimationFrame(frame);
})();
</script>
