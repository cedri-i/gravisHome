<canvas id="sky-comets" aria-hidden="true"></canvas>

<style>
  #sky-comets {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: 1;
    mix-blend-mode: screen;
  }

  :root[data-theme="light"] #sky-comets {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    #sky-comets {
      display: none;
    }
  }
</style>

<script is:inline>
(() => {
  const canvas = document.getElementById("sky-comets");
  if (!canvas || window.__SKY_COMETS__) return;
  window.__SKY_COMETS__ = true;

  const ctx = canvas.getContext("2d", { alpha: true });
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  if (reduceMotion.matches) return;

  let w = 0;
  let h = 0;
  let dpr = 1;
  let lastTime = performance.now();
  let nextCometTime = 900 + Math.random() * 1800;

  const comets = [];

  function rand(min, max) {
    return min + Math.random() * (max - min);
  }

  function clamp(v, min, max) {
    return Math.max(min, Math.min(max, v));
  }

  function resize() {
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    w = window.innerWidth;
    h = window.innerHeight;

    canvas.width = Math.floor(w * dpr);
    canvas.height = Math.floor(h * dpr);
    canvas.style.width = w + "px";
    canvas.style.height = h + "px";

    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function createComet() {
    const startX = rand(w + 120, w * 1.32);
    const startY = rand(-h * 0.06, h * 0.34);

    const endX = rand(-w * 0.42, w * 0.12);
    const endY = startY + rand(h * 0.28, h * 0.64);

    const power = rand(0.55, 0.95);
    const life = rand(4.0, 6.2);

    const fragments = [];
    const fragmentCount = Math.floor(rand(7, 14) * power);

    for (let i = 0; i < fragmentCount; i++) {
      fragments.push({
        delay: rand(0.12, 0.78),
        offset: rand(0.12, 0.82),
        side: rand(-1, 1),
        size: rand(0.35, 1.05) * power,
        drift: rand(0.35, 1.15),
        alpha: rand(0.2, 0.55),
        warm: Math.random() > 0.72
      });
    }

    comets.push({
      startX,
      startY,
      endX,
      endY,
      age: 0,
      life,
      power,
      curve: rand(-34, 34),
      wobble: rand(0, Math.PI * 2),
      fragments,
      headX: startX,
      headY: startY,
      tailX: startX,
      tailY: startY,
      hitRadius: 30 + 18 * power
    });
  }

  function getCometPosition(c, t) {
    const ease = 1 - Math.pow(1 - t, 2.25);

    const x = c.startX + (c.endX - c.startX) * ease;
    const y = c.startY + (c.endY - c.startY) * ease;

    const arc = Math.sin(t * Math.PI) * c.curve;
    const wobble = Math.sin(t * Math.PI * 5 + c.wobble) * 1.8 * c.power;

    return {
      x,
      y: y + arc + wobble
    };
  }

  function drawTail(c, head, prev, t, fade) {
    const vx = head.x - prev.x;
    const vy = head.y - prev.y;
    const len = Math.hypot(vx, vy) || 1;

    const dx = vx / len;
    const dy = vy / len;

    const tx = -dx;
    const ty = -dy;

    const px = -dy;
    const py = dx;

    const pulse = 0.88 + 0.12 * Math.sin(t * Math.PI);
    const tailLength = (280 + 230 * c.power) * pulse;
    const coreWidth = (1.35 + 1.9 * c.power) * fade;
    const glowWidth = (6 + 7 * c.power) * fade;

    const tailEndX = head.x + tx * tailLength;
    const tailEndY = head.y + ty * tailLength;

    ctx.globalCompositeOperation = "lighter";
    ctx.lineCap = "round";

    const glow = ctx.createLinearGradient(head.x, head.y, tailEndX, tailEndY);
    glow.addColorStop(0, `rgba(255, 255, 255, ${0.5 * fade})`);
    glow.addColorStop(0.1, `rgba(170, 232, 255, ${0.34 * fade})`);
    glow.addColorStop(0.46, `rgba(74, 163, 255, ${0.12 * fade})`);
    glow.addColorStop(1, "rgba(0, 0, 0, 0)");

    ctx.strokeStyle = glow;
    ctx.lineWidth = glowWidth;
    ctx.beginPath();
    ctx.moveTo(head.x, head.y);
    ctx.lineTo(tailEndX, tailEndY);
    ctx.stroke();

    const core = ctx.createLinearGradient(head.x, head.y, tailEndX, tailEndY);
    core.addColorStop(0, `rgba(255, 255, 255, ${0.95 * fade})`);
    core.addColorStop(0.08, `rgba(222, 249, 255, ${0.7 * fade})`);
    core.addColorStop(0.38, `rgba(126, 203, 255, ${0.28 * fade})`);
    core.addColorStop(1, "rgba(0, 0, 0, 0)");

    ctx.strokeStyle = core;
    ctx.lineWidth = Math.max(0.8, coreWidth);
    ctx.beginPath();
    ctx.moveTo(head.x, head.y);
    ctx.lineTo(tailEndX, tailEndY);
    ctx.stroke();

    for (let i = 0; i < 4; i++) {
      const k = i / 3;
      const side = (i - 1.5) * coreWidth * rand(0.55, 0.9);
      const streamLength = tailLength * rand(0.42, 0.88);
      const streamFade = (0.12 - k * 0.018) * fade;

      ctx.strokeStyle = `rgba(205, 238, 255, ${streamFade})`;
      ctx.lineWidth = Math.max(0.45, coreWidth * rand(0.2, 0.38));
      ctx.beginPath();
      ctx.moveTo(head.x + px * side, head.y + py * side);
      ctx.lineTo(
        head.x + tx * streamLength + px * side * 0.22,
        head.y + ty * streamLength + py * side * 0.22
      );
      ctx.stroke();
    }

    return { dx, dy, tx, ty, px, py, tailLength, tailWidth: glowWidth, coreWidth, tailEndX, tailEndY };
  }

  function drawFragments(c, head, dir, t, fade) {
    ctx.globalCompositeOperation = "lighter";

    for (const f of c.fragments) {
      const local = clamp((t - f.delay) / (1 - f.delay), 0, 1);
      if (local <= 0 || local >= 1) continue;

      const back = dir.tailLength * f.offset * local;
      const side = f.side * dir.coreWidth * f.drift * Math.sin(local * Math.PI);

      const x = head.x + dir.tx * back + dir.px * side;
      const y = head.y + dir.ty * back + dir.py * side;

      const a = f.alpha * fade * (1 - local);
      const hue = f.warm ? rand(38, 48) : rand(196, 214);

      const glow = ctx.createRadialGradient(x, y, 0, x, y, f.size * 5);
      glow.addColorStop(0, `hsla(${hue}, 100%, 82%, ${0.42 * a})`);
      glow.addColorStop(0.5, `hsla(${hue}, 90%, 62%, ${0.12 * a})`);
      glow.addColorStop(1, "rgba(0,0,0,0)");

      ctx.fillStyle = glow;
      ctx.beginPath();
      ctx.arc(x, y, f.size, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  function drawComaAndCore(c, head, dir, t, fade) {
    const coreR = (2.1 + 1.8 * c.power) * (0.94 + Math.sin(t * Math.PI * 9) * 0.05);
    const glowR = coreR * 5.2;

    ctx.globalCompositeOperation = "lighter";

    const glow = ctx.createRadialGradient(head.x, head.y, 0, head.x, head.y, glowR);
    glow.addColorStop(0, `rgba(255,255,255,${0.78 * fade})`);
    glow.addColorStop(0.2, `rgba(182,235,255,${0.42 * fade})`);
    glow.addColorStop(0.62, `rgba(85,175,255,${0.13 * fade})`);
    glow.addColorStop(1, "rgba(0,0,0,0)");

    ctx.fillStyle = glow;
    ctx.beginPath();
    ctx.arc(head.x, head.y, glowR, 0, Math.PI * 2);
    ctx.fill();

    ctx.save();
    ctx.translate(head.x, head.y);
    ctx.rotate(Math.atan2(dir.dy, dir.dx));

    const spark = ctx.createLinearGradient(-coreR * 1.8, 0, coreR * 4.2, 0);
    spark.addColorStop(0, `rgba(120,210,255,${0.08 * fade})`);
    spark.addColorStop(0.42, `rgba(255,255,255,${0.95 * fade})`);
    spark.addColorStop(1, `rgba(255,232,172,${0.34 * fade})`);

    ctx.fillStyle = spark;
    ctx.beginPath();
    ctx.ellipse(0, 0, coreR * 3.2, coreR * 0.78, 0, 0, Math.PI * 2);
    ctx.fill();

    ctx.strokeStyle = `rgba(255,255,255,${0.62 * fade})`;
    ctx.lineWidth = Math.max(0.7, coreR * 0.26);
    ctx.beginPath();
    ctx.moveTo(-coreR * 4.5, 0);
    ctx.lineTo(coreR * 5.8, 0);
    ctx.stroke();

    ctx.restore();
  }

  function explodeComet(c, x, y) {
    const burst = document.createElement("span");
    burst.className = "sky-burst";
    burst.style.left = x + "px";
    burst.style.top = y + "px";
    document.body.append(burst);
    burst.addEventListener("animationend", () => burst.remove(), { once: true });
    const index = comets.indexOf(c);
    if (index >= 0) comets.splice(index, 1);
  }

  function distanceToSegment(px, py, ax, ay, bx, by) {
    const vx = bx - ax;
    const vy = by - ay;
    const wx = px - ax;
    const wy = py - ay;
    const len2 = vx * vx + vy * vy || 1;
    const t = clamp((wx * vx + wy * vy) / len2, 0, 1);
    const x = ax + vx * t;
    const y = ay + vy * t;
    return Math.hypot(px - x, py - y);
  }

  function handleClick(event) {
    if (document.documentElement.dataset.theme === "light") return;

    for (let i = comets.length - 1; i >= 0; i--) {
      const c = comets[i];
      const headHit = Math.hypot(event.clientX - c.headX, event.clientY - c.headY);
      const tailHit = distanceToSegment(event.clientX, event.clientY, c.headX, c.headY, c.tailX, c.tailY);

      if (headHit < c.hitRadius || tailHit < Math.max(18, c.hitRadius * 0.38)) {
        explodeComet(c, event.clientX, event.clientY);
        break;
      }
    }
  }

  function frame(now) {
    const dt = Math.min((now - lastTime) / 1000, 0.033);
    lastTime = now;

    ctx.clearRect(0, 0, w, h);

    nextCometTime -= dt * 1000;
    if (nextCometTime <= 0) {
      createComet();
      nextCometTime = rand(8500, 18000);
    }

    for (let i = comets.length - 1; i >= 0; i--) {
      const c = comets[i];
      c.age += dt;

      const t = c.age / c.life;
      if (t >= 1) {
        comets.splice(i, 1);
        continue;
      }

      const fadeIn = clamp(t / 0.12, 0, 1);
      const fadeOut = clamp((1 - t) / 0.22, 0, 1);
      const fade = fadeIn * fadeOut;

      const head = getCometPosition(c, t);
      const prev = getCometPosition(c, Math.max(0, t - 0.012));

      const dir = drawTail(c, head, prev, t, fade);
      c.headX = head.x;
      c.headY = head.y;
      c.tailX = dir.tailEndX;
      c.tailY = dir.tailEndY;
      drawFragments(c, head, dir, t, fade);
      drawComaAndCore(c, head, dir, t, fade, dt);
    }

    requestAnimationFrame(frame);
  }

  resize();
  window.addEventListener("resize", resize, { passive: true });

  window.addEventListener("click", handleClick, { passive: true });

  setTimeout(createComet, 900);
  requestAnimationFrame(frame);
})();
</script>
