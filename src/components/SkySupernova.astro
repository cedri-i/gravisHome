<canvas id="sky-supernova" aria-hidden="true"></canvas>

<style>
  #sky-supernova {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
    z-index: -1;
    mix-blend-mode: screen;
  }


  :root[data-theme="light"] #sky-supernova {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    #sky-supernova {
      display: none;
    }
  }
</style>

<script is:inline>
(() => {
  const canvas = document.getElementById("sky-supernova");
  if (!canvas || window.__SKY_SUPERNOVA__) return;
  window.__SKY_SUPERNOVA__ = true;

  const ctx = canvas.getContext("2d", { alpha: true });
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  if (reduceMotion.matches) return;

  let w = 0;
  let h = 0;
  let dpr = 1;
  let lastTime = performance.now();
  let nextNovaTime = 1200 + Math.random() * 2500;

  const novas = [];
  const dust = [];

  function resize() {
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    w = window.innerWidth;
    h = window.innerHeight;

    canvas.width = Math.floor(w * dpr);
    canvas.height = Math.floor(h * dpr);
    canvas.style.width = w + "px";
    canvas.style.height = h + "px";

    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function rand(min, max) {
    return min + Math.random() * (max - min);
  }

  function createNova() {
    const x = rand(w * 0.16, w * 0.84);
    const y = rand(h * 0.12, h * 0.72);
    const power = rand(0.8, 1.35);

    const particles = [];
    const count = Math.floor(rand(90, 150) * power);

    for (let i = 0; i < count; i++) {
      const a = Math.random() * Math.PI * 2;
      const speed = rand(0.25, 2.7) * power;
      const size = rand(0.7, 2.8) * power;
      const warm = Math.random();

      particles.push({
        x,
        y,
        vx: Math.cos(a) * speed * rand(0.55, 1.35),
        vy: Math.sin(a) * speed * rand(0.55, 1.35),
        size,
        life: rand(0.78, 1.25),
        age: 0,
        spin: rand(-0.02, 0.02),
        hue: warm > 0.55 ? rand(32, 52) : rand(198, 230),
        alpha: rand(0.55, 1)
      });
    }

    novas.push({
      x,
      y,
      power,
      age: 0,
      life: rand(2.8, 4.2),
      particles,
      ringNoise: rand(0.85, 1.18)
    });
  }

  function drawCore(n, t, fade) {
    const flash = Math.max(0, 1 - Math.abs(t - 0.18) / 0.18);
    const pulse = Math.sin(t * Math.PI * 5) * 0.08 + 1;
    const r = (18 + 180 * Math.pow(t, 0.72)) * n.power;

    const core = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, r);
    core.addColorStop(0, `rgba(255,255,255,${0.95 * fade})`);
    core.addColorStop(0.08, `rgba(185,225,255,${0.8 * fade})`);
    core.addColorStop(0.22, `rgba(92,170,255,${0.35 * fade})`);
    core.addColorStop(0.55, `rgba(255,156,72,${0.16 * fade})`);
    core.addColorStop(1, "rgba(0,0,0,0)");

    ctx.globalCompositeOperation = "lighter";
    ctx.fillStyle = core;
    ctx.beginPath();
    ctx.arc(n.x, n.y, r * pulse, 0, Math.PI * 2);
    ctx.fill();

    if (flash > 0) {
      ctx.save();
      ctx.translate(n.x, n.y);
      ctx.rotate(-0.35);
      ctx.strokeStyle = `rgba(255,255,255,${flash * 0.75})`;
      ctx.lineWidth = 1.2;
      ctx.beginPath();
      ctx.moveTo(-r * 1.7, 0);
      ctx.lineTo(r * 1.7, 0);
      ctx.moveTo(0, -r * 0.75);
      ctx.lineTo(0, r * 0.75);
      ctx.stroke();
      ctx.restore();
    }
  }

  function drawShockwave(n, t, fade) {
    const radius = (34 + 260 * Math.pow(t, 0.88)) * n.power;
    const width = (10 + 18 * t) * n.power;

    ctx.globalCompositeOperation = "lighter";
    ctx.lineWidth = width;
    ctx.strokeStyle = `rgba(156,210,255,${0.26 * fade})`;
    ctx.beginPath();
    ctx.arc(n.x, n.y, radius, 0, Math.PI * 2);
    ctx.stroke();

    ctx.lineWidth = width * 0.45;
    ctx.strokeStyle = `rgba(255,194,106,${0.16 * fade})`;
    ctx.beginPath();
    ctx.arc(n.x, n.y, radius * n.ringNoise, 0, Math.PI * 2);
    ctx.stroke();
  }

  function drawParticles(n, dt) {
    for (const p of n.particles) {
      p.age += dt;
      p.x += p.vx * dt * 60;
      p.y += p.vy * dt * 60;

      p.vx *= 0.992;
      p.vy *= 0.992;
      p.vy += 0.004 * dt * 60;

      const k = Math.max(0, 1 - p.age / p.life);
      if (k <= 0) continue;

      const glow = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.size * 8);
      glow.addColorStop(0, `hsla(${p.hue}, 100%, 82%, ${0.45 * k * p.alpha})`);
      glow.addColorStop(0.28, `hsla(${p.hue}, 95%, 58%, ${0.2 * k * p.alpha})`);
      glow.addColorStop(1, "rgba(0,0,0,0)");

      ctx.globalCompositeOperation = "lighter";
      ctx.fillStyle = glow;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size * (1 + 2.2 * (1 - k)), 0, Math.PI * 2);
      ctx.fill();
    }
  }

  function createDust(dt) {
    if (dust.length > 80 || Math.random() > 0.16) return;

    dust.push({
      x: rand(0, w),
      y: rand(0, h),
      r: rand(0.3, 1.3),
      a: rand(0.04, 0.12),
      vx: rand(-0.015, 0.015),
      vy: rand(-0.006, 0.01),
      hue: Math.random() > 0.5 ? rand(210, 230) : rand(35, 50)
    });
  }

  function drawDust(dt) {
    createDust(dt);

    for (const p of dust) {
      p.x += p.vx * dt * 60;
      p.y += p.vy * dt * 60;

      if (p.x < -20) p.x = w + 20;
      if (p.x > w + 20) p.x = -20;
      if (p.y < -20) p.y = h + 20;
      if (p.y > h + 20) p.y = -20;

      ctx.globalCompositeOperation = "lighter";
      ctx.fillStyle = `hsla(${p.hue}, 90%, 76%, ${p.a})`;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fill();
    }
  }

  function frame(now) {
    const dt = Math.min((now - lastTime) / 1000, 0.033);
    lastTime = now;

    ctx.clearRect(0, 0, w, h);
    drawDust(dt);

    nextNovaTime -= dt * 1000;
    if (nextNovaTime <= 0) {
      createNova();
      nextNovaTime = rand(6500, 14500);
    }

    for (let i = novas.length - 1; i >= 0; i--) {
      const n = novas[i];
      n.age += dt;

      const t = n.age / n.life;
      const fade = Math.max(0, 1 - t);
      const shapedFade = Math.pow(fade, 1.25);

      drawCore(n, t, shapedFade);
      drawShockwave(n, t, shapedFade);
      drawParticles(n, dt);

      if (n.age > n.life) novas.splice(i, 1);
    }

    requestAnimationFrame(frame);
  }

  window.addEventListener("resize", resize, { passive: true });
  resize();

  setTimeout(createNova, 700);
  requestAnimationFrame(frame);
})();
</script>
