---
import '../styles/waterpond.css';
---

<div id="water-pond" aria-hidden="true">
  <button id="fish-food-bag" type="button" aria-label="fish food"></button>
  <button id="fish-net-tool" type="button" aria-label="fish net" tabindex="-1"></button>

  <span class="pond-leaf leaf-1"></span>
  <span class="pond-leaf leaf-2"></span>
  <span class="pond-leaf leaf-3"></span>
  <span class="pond-lotus lotus-1"></span>
  <span class="pond-lotus lotus-2"></span>
  <span id="fish-net-cursor" aria-hidden="true" hidden></span>

  <span class="pond-turtle turtle-1">
    <span class="turtle-head"></span>
    <span class="turtle-leg leg-1"></span>
    <span class="turtle-leg leg-2"></span>
    <span class="turtle-leg leg-3"></span>
    <span class="turtle-leg leg-4"></span>
  </span>

  <span class="pond-fish fish-1 koi-orange">
    <span class="fish-tail"></span>
    <span class="fish-fin top"></span>
    <span class="fish-fin side"></span>
    <span class="fish-eye"></span>
    <span class="fish-mark mark-1"></span>
    <span class="fish-mark mark-2"></span>
  </span>

  <span class="pond-fish fish-2 koi-red">
    <span class="fish-tail"></span>
    <span class="fish-fin top"></span>
    <span class="fish-fin side"></span>
    <span class="fish-eye"></span>
    <span class="fish-mark mark-1"></span>
    <span class="fish-mark mark-2"></span>
  </span>

  <span class="pond-fish mini-fish mini-1 koi-white"></span>
  <span class="pond-fish mini-fish mini-2 koi-gold"></span>
  <span class="pond-fish mini-fish mini-3 koi-blue"></span>
  <span class="pond-fish mini-fish mini-4 koi-white"></span>
  <span class="pond-fish mini-fish mini-5 koi-gold"></span>
</div>

<script is:inline>
  (() => {
    const pond = document.getElementById('water-pond');
    const foodBag = document.getElementById('fish-food-bag');
    const fishNet = document.getElementById('fish-net-tool');
    const fishNetCursor = document.getElementById('fish-net-cursor');

    if (!pond) return;

    let feedingMode = false;
    let foodTarget = null;
    let lastUserActivity = performance.now();
    const swimmers = [];
    const lotusPads = [];
    const clamp = (value, min, max) => Math.max(min, Math.min(max, value));
    const angleDiff = (target, current) => ((target - current + 540) % 360) - 180;
    const rand = (min, max) => min + Math.random() * (max - min);

    function createRipple(x, y, strength = 1) {
      const rings = strength > 1 ? 3 : 2;

      for (let i = 0; i < rings; i++) {
        const ripple = document.createElement('span');
        ripple.className = 'pond-ripple';
        ripple.style.left = `${x}px`;
        ripple.style.top = `${y}px`;
        ripple.style.setProperty('--ripple-delay', `${i * 110}ms`);
        ripple.style.setProperty('--ripple-size', `${(strength > 1 ? 150 : 112) + i * 34}px`);
        ripple.style.setProperty('--ripple-opacity', `${0.42 - i * 0.08}`);
        pond.appendChild(ripple);
        setTimeout(() => ripple.remove(), 2200 + i * 120);
      }
    }

    function setNetMode(next) {
      fishNet?.classList.toggle('is-active', next);
      fishNet?.setAttribute('aria-pressed', String(next));
      document.body.classList.toggle('is-netting-fish', next);
      fishNetCursor?.toggleAttribute('hidden', !next);
    }

    function setFeedingMode(next) {
      if (next) setNetMode(false);
      feedingMode = next;
      foodBag?.classList.toggle('is-active', feedingMode);
      foodBag?.setAttribute('aria-pressed', String(feedingMode));
      document.body.classList.toggle('is-feeding-fish', feedingMode);
    }

    foodBag?.addEventListener('click', (event) => {
      wakeRestingTurtle();
      event.stopPropagation();
      setFeedingMode(!feedingMode);
    });

    fishNet?.addEventListener('click', (event) => {
      wakeRestingTurtle();
      event.stopPropagation();
      const next = !fishNet.classList.contains('is-active');
      if (next) setFeedingMode(false);
      setNetMode(next);
    });

    function initSwimmers() {
      const startPoints = [
        { selector: '.fish-1', x: 0.18, y: 0.58, vx: 0.35, vy: 0.08, size: 1.08, kind: 'big' },
        { selector: '.fish-2', x: 0.72, y: 0.36, vx: -0.28, vy: -0.05, size: 0.92, kind: 'big' },
        { selector: '.mini-1', x: 0.12, y: 0.28, vx: 0.24, vy: 0.04, size: 0.48, kind: 'mini' },
        { selector: '.mini-2', x: 0.34, y: 0.74, vx: 0.2, vy: -0.03, size: 0.42, kind: 'mini' },
        { selector: '.mini-3', x: 0.58, y: 0.22, vx: -0.22, vy: 0.02, size: 0.46, kind: 'mini' },
        { selector: '.mini-4', x: 0.82, y: 0.68, vx: -0.25, vy: -0.05, size: 0.4, kind: 'mini' },
        { selector: '.mini-5', x: 0.48, y: 0.48, vx: 0.18, vy: 0.03, size: 0.44, kind: 'mini' },
        { selector: '.turtle-1', x: 0.68, y: 0.66, vx: -0.08, vy: 0.025, size: 1, kind: 'turtle' },
      ];

      for (const p of startPoints) {
        const el = document.querySelector(p.selector);
        if (!el) continue;

        swimmers.push({
          el,
          kind: p.kind,
          x: window.innerWidth * p.x,
          y: window.innerHeight * p.y,
          vx: p.vx,
          vy: p.vy,
          size: p.size,
          angle: Math.atan2(p.vy, p.vx) * 180 / Math.PI,
          wander: Math.random() * Math.PI * 2,
          speedFactor: p.kind === 'turtle' ? 0.72 : 1.28 + Math.random() * 0.52,
          wanderSpeed: p.kind === 'turtle' ? 0.004 : 0.010 + Math.random() * 0.008,
          nextLotusAt: p.kind === 'turtle' ? Infinity : performance.now() + rand(2600, 9800),
          lotusVisit: null,
          turtleState: p.kind === 'turtle' ? 'roam' : null,
          turtleRestTarget: null,
          turtleRestUntil: 0,
        });
      }

      document.querySelectorAll('.pond-lotus').forEach((el) => lotusPads.push(el));
    }

    function clearFoodTarget() {
      foodTarget = null;
    }

    function getElementCenter(el) {
      const rect = el.getBoundingClientRect();
      return {
        x: rect.left + rect.width / 2,
        y: rect.top + rect.height / 2,
        width: rect.width,
        height: rect.height,
      };
    }

    function startLotusVisit(fish, now) {
      if (!lotusPads.length || fish.kind === 'turtle' || foodTarget) return;
      const pad = lotusPads[Math.floor(Math.random() * lotusPads.length)];
      const center = getElementCenter(pad);
      const clockwise = Math.random() > 0.5 ? 1 : -1;
      fish.lotusVisit = {
        pad,
        startedAt: now,
        expiresAt: now + rand(5200, 9000),
        angle: Math.atan2(fish.y - center.y, fish.x - center.x),
        radius: rand(fish.kind === 'mini' ? 54 : 72, fish.kind === 'mini' ? 86 : 112),
        clockwise,
        orbitSpeed: rand(0.010, 0.018) * clockwise,
      };
    }

    function clearLotusVisit(fish, now) {
      fish.lotusVisit = null;
      fish.nextLotusAt = now + rand(9500, 21000);
      fish.vx += rand(-0.5, 0.5);
      fish.vy += rand(-0.32, 0.32);
    }

    function getRestButtonTarget() {
      const candidates = [foodBag, fishNet].filter(Boolean);
      if (!candidates.length) return null;
      const target = candidates[Math.floor(Math.random() * candidates.length)];
      const rect = target.getBoundingClientRect();
      return {
        x: rect.left + rect.width * rand(0.36, 0.64),
        y: rect.top + rect.height * rand(0.32, 0.55),
      };
    }

    function wakeRestingTurtle() {
      lastUserActivity = performance.now();
      for (const turtle of swimmers) {
        if (turtle.kind !== 'turtle' || turtle.turtleState === 'roam') continue;
        turtle.turtleState = 'leaving';
        turtle.turtleRestTarget = null;
        turtle.turtleRestUntil = lastUserActivity + 1800;
        turtle.el.classList.remove('is-resting');
        turtle.vx += turtle.x < window.innerWidth / 2 ? -0.75 : 0.75;
        turtle.vy += rand(-0.28, 0.28);
      }
    }

    function showCatchResult(caught) {
      pond.querySelector('.pond-catch-result')?.remove();

      const result = document.createElement('div');
      const x = caught.x;
      const y = caught.y;
      const caughtFish = caught.el.cloneNode(true);

      caughtFish.removeAttribute('style');
      caughtFish.classList.add('pond-caught-swimmer', `caught-${caught.kind}`);
      caughtFish.setAttribute('aria-hidden', 'true');

      result.className = 'pond-catch-result';
      result.setAttribute('role', 'dialog');
      result.setAttribute('aria-label', '捞到鱼之后的选择');
      result.style.left = clamp(x, 150, window.innerWidth - 150) + 'px';
      result.style.top = clamp(y - 48, 135, window.innerHeight - 150) + 'px';
      result.innerHTML = [
        '<div class="pond-caught-net" aria-hidden="true">',
          '<span class="pond-caught-handle"></span>',
          '<span class="pond-caught-rim"></span>',
          '<span class="pond-caught-mesh"></span>',
          '<span class="pond-caught-fish-slot"></span>',
        '</div>',
        '<div class="pond-catch-actions" aria-label="捞到的鱼怎么办">',
          '<button type="button">带走</button>',
          '<button type="button">放生</button>',
        '</div>',
      ].join('');

      result.querySelector('.pond-caught-fish-slot')?.replaceWith(caughtFish);

      result.querySelectorAll('button').forEach((button) => {
        button.addEventListener('click', (event) => {
          event.stopPropagation();
          result.classList.add('is-dismissed');
          setTimeout(() => result.remove(), 220);
        });
      });

      pond.appendChild(result);
      setTimeout(() => result.classList.add('is-ready'), 20);
    }

    function tryCatchFish(x, y) {
      let target = null;
      let bestDistance = Infinity;

      for (const fish of swimmers) {
        if (fish.kind === 'turtle') continue;

        const distance = Math.hypot(fish.x - x, fish.y - y);
        const radius = fish.kind === 'mini' ? 58 : 76;

        if (distance < radius && distance < bestDistance) {
          target = fish;
          bestDistance = distance;
        }
      }

      createRipple(x, y, target ? 1.45 : 1);

      if (!target) return;

      setNetMode(false);
      showCatchResult(target);

      const dx = target.x - x || (Math.random() - 0.5);
      const dy = target.y - y || (Math.random() - 0.5);
      const distance = Math.hypot(dx, dy) || 1;
      target.vx += (dx / distance) * 1.8;
      target.vy += (dy / distance) * 1.25;
    }

    function animateSwimmers(now = performance.now()) {
      if (foodTarget && now > foodTarget.expiresAt) clearFoodTarget();

      let dinersNearFood = 0;

      for (const fish of swimmers) {
        fish.wander += fish.wanderSpeed;

        const isTurtle = fish.kind === 'turtle';
        const isMini = fish.kind === 'mini';
        let targetVx = Math.cos(fish.wander) * (isTurtle ? 0.16 : 0.48 * fish.speedFactor);
        let targetVy = Math.sin(fish.wander * 0.82) * (isTurtle ? 0.08 : 0.2 * fish.speedFactor);

        if (!isTurtle && !foodTarget && !fish.lotusVisit && now > fish.nextLotusAt) {
          startLotusVisit(fish, now);
        }

        if (fish.lotusVisit) {
          const visit = fish.lotusVisit;
          const center = getElementCenter(visit.pad);
          visit.angle += visit.orbitSpeed;
          const wobble = Math.sin((now - visit.startedAt) * 0.003) * 8;
          const targetX = center.x + Math.cos(visit.angle) * (visit.radius + wobble);
          const targetY = center.y + Math.sin(visit.angle) * (visit.radius * 0.58 + wobble * 0.4);
          const dx = targetX - fish.x;
          const dy = targetY - fish.y;
          const d = Math.hypot(dx, dy) || 1;
          const tangentX = -Math.sin(visit.angle) * visit.clockwise;
          const tangentY = Math.cos(visit.angle) * visit.clockwise * 0.58;

          targetVx += (dx / d) * 0.62 * fish.speedFactor + tangentX * 0.52 * fish.speedFactor;
          targetVy += (dy / d) * 0.48 * fish.speedFactor + tangentY * 0.38 * fish.speedFactor;

          if (now > visit.expiresAt) clearLotusVisit(fish, now);
        }

        if (foodTarget) {
          if (fish.lotusVisit) clearLotusVisit(fish, now);
          const dx = foodTarget.x - fish.x;
          const dy = foodTarget.y - fish.y;
          const d = Math.hypot(dx, dy);
          const pull = isTurtle ? 0.42 : (isMini ? 0.92 : 1.08) * fish.speedFactor;

          if (d > 20) {
            targetVx += (dx / d) * pull;
            targetVy += (dy / d) * pull * 0.78;
          } else {
            dinersNearFood += 1;
            targetVx *= 0.35;
            targetVy *= 0.35;
          }
        }

        if (isTurtle) {
          const idleFor = now - lastUserActivity;

          if (fish.turtleState === 'roam' && idleFor > 11500) {
            const restTarget = getRestButtonTarget();
            if (restTarget) {
              fish.turtleState = 'approach';
              fish.turtleRestTarget = restTarget;
            }
          }

          if (fish.turtleState === 'approach' && fish.turtleRestTarget) {
            const dx = fish.turtleRestTarget.x - fish.x;
            const dy = fish.turtleRestTarget.y - fish.y;
            const d = Math.hypot(dx, dy) || 1;
            targetVx += (dx / d) * 0.88;
            targetVy += (dy / d) * 0.58;

            if (d < 18) {
              fish.turtleState = 'resting';
              fish.turtleRestUntil = now + rand(5200, 8400);
              fish.el.classList.add('is-resting');
            }
          }

          if (fish.turtleState === 'resting' && fish.turtleRestTarget) {
            targetVx += (fish.turtleRestTarget.x - fish.x) * 0.05;
            targetVy += (fish.turtleRestTarget.y - fish.y) * 0.05;
            targetVx *= 0.08;
            targetVy *= 0.08;

            if (now > fish.turtleRestUntil) wakeRestingTurtle();
          }

          if (fish.turtleState === 'leaving' && now > fish.turtleRestUntil) {
            fish.turtleState = 'roam';
          }
        }

        fish.vx += (targetVx - fish.vx) * (isTurtle ? 0.012 : 0.022);
        fish.vy += (targetVy - fish.vy) * (isTurtle ? 0.012 : 0.022);

        for (const other of swimmers) {
          if (other === fish || other.kind === 'turtle') continue;

          const dx = fish.x - other.x;
          const dy = fish.y - other.y;
          const d = Math.hypot(dx, dy);
          const comfort = isMini ? 58 : 82;

          if (d > 0.1 && d < comfort) {
            const push = (comfort - d) / comfort;
            fish.vx += (dx / d) * push * (isMini ? 0.018 : 0.028);
            fish.vy += (dy / d) * push * (isMini ? 0.015 : 0.024);
          }
        }

        const speed = Math.hypot(fish.vx, fish.vy);
        const maxSpeed = isTurtle
          ? fish.turtleState === 'resting' ? 0.18 : fish.turtleState === 'approach' ? 1.05 : 0.72
          : (fish.lotusVisit ? 1.65 : foodTarget ? 2.05 : 2.65) * fish.speedFactor;

        if (speed > maxSpeed) {
          fish.vx = (fish.vx / speed) * maxSpeed;
          fish.vy = (fish.vy / speed) * maxSpeed;
        }

        fish.x += fish.vx;
        fish.y += fish.vy;

        if (fish.x < -140) fish.x = window.innerWidth + 140;
        if (fish.x > window.innerWidth + 140) fish.x = -140;
        if (fish.y < 86) {
          fish.y = 86;
          fish.vy = Math.abs(fish.vy) * 0.72;
        }
        if (fish.y > window.innerHeight - 82) {
          fish.y = window.innerHeight - 82;
          fish.vy = -Math.abs(fish.vy) * 0.72;
        }

        if (speed > 0.035) {
          const targetAngle = Math.atan2(fish.vy, fish.vx) * 180 / Math.PI;
          const turnRate = isTurtle ? 0.035 : isMini ? 0.055 : 0.075;
          fish.angle += angleDiff(targetAngle, fish.angle) * turnRate;
        }

        fish.el.style.transform = `translate3d(${fish.x}px, ${fish.y}px, 0) rotate(${fish.angle}deg) scale(${fish.size})`;
      }

      if (foodTarget && dinersNearFood >= Math.max(3, Math.ceil(swimmers.length * 0.45)) && now > foodTarget.createdAt + 1900) {
        clearFoodTarget();
      }

      requestAnimationFrame(animateSwimmers);
    }

    let lastRipple = 0;

    window.addEventListener('pointermove', (event) => {
      if (document.documentElement.dataset.theme !== 'light') return;

      wakeRestingTurtle();
      const now = Date.now();

      if (now - lastRipple > 145) {
        lastRipple = now;
        createRipple(event.clientX, event.clientY, 0.85);
      }

      if (fishNet?.classList.contains('is-active') && fishNetCursor) {
        fishNetCursor.style.left = `${event.clientX}px`;
        fishNetCursor.style.top = `${event.clientY}px`;
      }

      if (feedingMode) return;

      for (const fish of swimmers) {
        if (fish.kind === 'turtle') continue;

        const dx = fish.x - event.clientX;
        const dy = fish.y - event.clientY;
        const d = Math.hypot(dx, dy);

        if (d < 180 && d > 0.1) {
          const force = (180 - d) / 180;
          fish.vx += (dx / d) * force * 0.55;
          fish.vy += (dy / d) * force * 0.42;
        }
      }
    });

    window.addEventListener('click', (event) => {
      wakeRestingTurtle();
      if (event.target.closest?.('#fish-food-bag, #fish-net-tool, .pond-catch-result')) return;
      if (document.documentElement.dataset.theme !== 'light') return;

      if (fishNet?.classList.contains('is-active')) {
        tryCatchFish(event.clientX, event.clientY);
        return;
      }

      if (!feedingMode) return;

      const now = performance.now();
      foodTarget = {
        x: event.clientX,
        y: event.clientY,
        createdAt: now,
        expiresAt: now + 4700,
      };

      for (let i = 0; i < 14; i++) {
        const food = document.createElement('span');
        food.className = 'fish-food-grain';
        food.style.left = `${event.clientX + (Math.random() - 0.5) * 42}px`;
        food.style.top = `${event.clientY + (Math.random() - 0.5) * 28}px`;
        food.style.setProperty('--food-drift', `${(Math.random() - 0.5) * 32}px`);
        pond.appendChild(food);
        setTimeout(() => food.remove(), 4300);
      }

      createRipple(event.clientX, event.clientY, 1.5);
    });

    window.addEventListener('scroll', wakeRestingTurtle, { passive: true });
    window.addEventListener('wheel', wakeRestingTurtle, { passive: true });
    window.addEventListener('touchstart', wakeRestingTurtle, { passive: true });
    window.addEventListener('keydown', wakeRestingTurtle);

    window.addEventListener('resize', () => {
      for (const fish of swimmers) {
        fish.x = clamp(fish.x, -120, window.innerWidth + 120);
        fish.y = clamp(fish.y, 86, window.innerHeight - 82);
      }
    });

    initSwimmers();
    animateSwimmers();
  })();
</script>