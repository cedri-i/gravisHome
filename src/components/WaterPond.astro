---
import '../styles/waterpond.css';
---

<div id="water-pond" aria-hidden="true">
  <button id="fish-food-bag" type="button" aria-label="鱼食"></button>

  <span class="pond-leaf leaf-1"></span>
  <span class="pond-leaf leaf-2"></span>
  <span class="pond-leaf leaf-3"></span>

    <span class="pond-fish fish-1 koi-orange">
    <span class="fish-tail"></span>
    <span class="fish-fin top"></span>
    <span class="fish-fin side"></span>
    <span class="fish-eye"></span>
    <span class="fish-mark mark-1"></span>
    <span class="fish-mark mark-2"></span>
    </span>

    <span class="pond-fish fish-2 koi-red">
    <span class="fish-tail"></span>
    <span class="fish-fin top"></span>
    <span class="fish-fin side"></span>
    <span class="fish-eye"></span>
    <span class="fish-mark mark-1"></span>
    <span class="fish-mark mark-2"></span>
    </span>

    <span class="pond-fish mini-fish mini-1 koi-white"></span>
    <span class="pond-fish mini-fish mini-2 koi-gold"></span>
    <span class="pond-fish mini-fish mini-3 koi-blue"></span>
    <span class="pond-fish mini-fish mini-4 koi-white"></span>
    <span class="pond-fish mini-fish mini-5 koi-gold"></span>
</div>

<script is:inline>
  const pond = document.getElementById('water-pond');
  const foodBag = document.getElementById('fish-food-bag');

  let feedingMode = false;
  let foodTarget = null;
  const fishes = [];

  function createRipple(x, y) {
    if (!pond) return;

    const ripple = document.createElement('span');
    ripple.className = 'pond-ripple';
    ripple.style.left = `${x}px`;
    ripple.style.top = `${y}px`;
    pond.appendChild(ripple);

    setTimeout(() => ripple.remove(), 1500);
  }

  foodBag?.addEventListener('click', (event) => {
    event.stopPropagation();

    feedingMode = !feedingMode;
    foodBag.classList.toggle('is-active', feedingMode);
    document.body.classList.toggle('is-feeding-fish', feedingMode);
  });

function initFish() {
  const startPoints = [
    { x: 0.18, y: 0.58, vx: 0.35, vy: 0.08, size: 1.08 },
    { x: 0.72, y: 0.36, vx: -0.28, vy: -0.05, size: 0.92 },

    { x: 0.12, y: 0.28, vx: 0.24, vy: 0.04, size: 0.48 },
    { x: 0.34, y: 0.74, vx: 0.2, vy: -0.03, size: 0.42 },
    { x: 0.58, y: 0.22, vx: -0.22, vy: 0.02, size: 0.46 },
    { x: 0.82, y: 0.68, vx: -0.25, vy: -0.05, size: 0.4 },
    { x: 0.48, y: 0.48, vx: 0.18, vy: 0.03, size: 0.44 },
  ];

  document.querySelectorAll('.pond-fish').forEach((el, index) => {
    const p = startPoints[index];

    fishes.push({
      el,
      x: window.innerWidth * p.x,
      y: window.innerHeight * p.y,
      vx: p.vx,
      vy: p.vy,
      size: p.size,
      wander: Math.random() * Math.PI * 2,
    });
  });
}

  function animateFish() {
    for (const fish of fishes) {
      fish.wander += 0.01;

      let targetVx = Math.cos(fish.wander) * 0.45;
      let targetVy = Math.sin(fish.wander) * 0.18;

      fish.vx += (targetVx - fish.vx) * 0.015;
      fish.vy += (targetVy - fish.vy) * 0.015;

      if (foodTarget) {
        const dx = foodTarget.x - fish.x;
        const dy = foodTarget.y - fish.y;
        const d = Math.hypot(dx, dy);

        if (d > 10) {
          fish.vx += (dx / d) * 0.055;
          fish.vy += (dy / d) * 0.045;
        } else {
          fish.vx *= 0.65;
          fish.vy *= 0.65;
        }
      }

      for (const other of fishes) {
  if (other === fish) continue;

  const dx = fish.x - other.x;
  const dy = fish.y - other.y;
  const d = Math.hypot(dx, dy);

  if (d > 0.1 && d < 86) {
    const push = (86 - d) / 86;
    fish.vx += (dx / d) * push * 0.035;
    fish.vy += (dy / d) * push * 0.028;
  }
}

      const speed = Math.hypot(fish.vx, fish.vy);
      const maxSpeed = feedingMode ? 2.15 : 2.8;

      if (speed > maxSpeed) {
        fish.vx = (fish.vx / speed) * maxSpeed;
        fish.vy = (fish.vy / speed) * maxSpeed;
      }

      fish.x += fish.vx;
      fish.y += fish.vy;

      if (fish.x < -120) fish.x = window.innerWidth + 120;
      if (fish.x > window.innerWidth + 120) fish.x = -120;
      if (fish.y < 80 || fish.y > window.innerHeight - 80) fish.vy *= -0.75;

      const angle = Math.atan2(fish.vy, fish.vx) * 180 / Math.PI;

   fish.el.style.transform =
  `translate3d(${fish.x}px, ${fish.y}px, 0) rotate(${angle}deg) scale(${fish.size})`;
  }

    requestAnimationFrame(animateFish);
  }

  let lastRipple = 0;

  window.addEventListener('pointermove', (event) => {
    if (document.documentElement.dataset.theme !== 'light') return;

    const now = Date.now();

    if (now - lastRipple > 110) {
      lastRipple = now;
      createRipple(event.clientX, event.clientY);
    }

    if (feedingMode) return;

    for (const fish of fishes) {
      const dx = fish.x - event.clientX;
      const dy = fish.y - event.clientY;
      const d = Math.hypot(dx, dy);

      if (d < 180 && d > 0.1) {
        const force = (180 - d) / 180;
        fish.vx += (dx / d) * force * 0.9;
        fish.vy += (dy / d) * force * 0.7;
      }
    }
  });

  window.addEventListener('click', (event) => {
    if (!feedingMode) return;
    if (event.target.closest?.('#fish-food-bag')) return;

    foodTarget = {
      x: event.clientX,
      y: event.clientY,
    };

    for (let i = 0; i < 12; i++) {
      const food = document.createElement('span');
      food.className = 'fish-food-grain';
      food.style.left = `${event.clientX + (Math.random() - 0.5) * 36}px`;
      food.style.top = `${event.clientY + (Math.random() - 0.5) * 24}px`;

      pond?.appendChild(food);
      setTimeout(() => food.remove(), 4200);
    }

    createRipple(event.clientX, event.clientY);
  });

  initFish();
  animateFish();
</script>